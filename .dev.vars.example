FCM_VAPID_PUBLIC_KEY=
FCM_PROJECT_ID=
FIREBASE_PROJECT_ID=

# Preferred: paste the full Firebase service account JSON on one line.
# Never commit real values. Store real credentials only as Cloudflare Worker secrets.
FCM_SERVICE_ACCOUNT_JSON=

# Alternative if you do not use FCM_SERVICE_ACCOUNT_JSON:
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Optional local/debug switches.
ENVIRONMENT=
ALLOW_DEBUG_ENDPOINTS=
